  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::StoryTrigger
  objective: "\u041A\u043E\u0442\u044F\u0442 \u043D\u0435 \u043B\u043E\u0432\u044F\u0442,
    \u0438\u0445 \u0443\u0441\u043F\u043E\u043A\u0430\u0438\u0432\u0430\u044E\u0442.
    \u041F\u043E\u0434\u043E\u0439\u0434\u0438 \u043F\u043E\u0447\u0442\u0438 \u0432\u043F\u043B\u043E\u0442\u043D\u0443\u044E
    \u0438 \u0434\u0435\u0440\u0436\u0438 Shift..."
  story: "\u041E\u043D\u0438 \u0431\u043E\u044F\u0442\u0441\u044F \u0433\u0440\u043E\u0437\u044B.
    \u0418\u043C \u043D\u0443\u0436\u043D\u043E \u0441\u043F\u043E\u043A\u043E\u0439\u043D\u043E\u0435
    \u043C\u0443\u0440\u0447\u0430\u043D\u0438\u0435 \u0440\u044F\u0434\u043E\u043C,
    \u043F\u043E\u0441\u043B\u0435 \u044D\u0442\u043E\u0433\u043E \u043E\u043D\u0438
    \u0441\u0430\u043C\u0438 \u043F\u043E\u0439\u0434\u0443\u0442 \u0437\u0430 \u0442\u043E\u0431\u043E\u0439."
  messageSeconds: 6
  triggerOnce: 1
